# ── AI Providers ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...            # Claude 3.7 Sonnet (Analyst)
GOOGLE_API_KEY=AIza...                  # Gemini 2.5 Pro (Orchestrator) + Flash-Lite (Scout)
OPENAI_API_KEY=sk-...                   # GPT-4o mini (Extractor fallback)

# ── Search APIs ───────────────────────────────────────────────
TAVILY_API_KEY=tvly-...                 # AI-enriched supplemental search
SERPER_API_KEY=...                      # Google bulk search (cheap)

# ── API Security ──────────────────────────────────────────────
MICROSERVICE_BEARER_TOKEN=replace_with_secure_random_token
N8N_WEBHOOK_API_KEY=replace_with_secure_random_key

# ── Model Config (overrideable) ───────────────────────────────
ORCHESTRATOR_MODEL=gemini-2.5-pro-preview-03-25
SCOUT_MODEL=gemini-2.0-flash-lite
EXTRACTOR_FALLBACK_MODEL=gpt-4o-mini
ANALYST_MODEL=claude-3-7-sonnet-20250219

# ── Runtime ───────────────────────────────────────────────────
AGENT_TIMEOUT_SECONDS=30
MAX_RESULTS=15
PORT=8000
